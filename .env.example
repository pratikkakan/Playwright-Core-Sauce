# ──────────────────────────────────────────────────────────────────
# Environment configuration — copy this file to .env and fill in
# your values. Never commit .env to version control.
# ──────────────────────────────────────────────────────────────────

# ── Application URL ──────────────────────────────────────────────
# Base URL of the application under test (required).
BASE_URL=https://your-app.example.com

# API base URL if different from BASE_URL (optional).
# API_BASE_URL=https://api.your-app.example.com

# ── User Credentials ──────────────────────────────────────────────
# Keys must match the entries in src/data/users.ts.
# Add or remove user blocks to match the roles your app supports.

STANDARD_USER_NAME=
STANDARD_USER_PASSWORD=

PROBLEM_USER_NAME=
PROBLEM_USER_PASSWORD=

LOCKED_OUT_USER_NAME=
LOCKED_OUT_USER_PASSWORD=

PERFORMANCE_GLITCH_USER_NAME=
PERFORMANCE_GLITCH_USER_PASSWORD=
