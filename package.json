{
  "name": "playwright-sauce",
  "version": "1.0.0",
  "description": "Scalable Playwright E2E test framework for SauceDemo — TypeScript + ESM",
  "type": "module",
  "scripts": {
    "test": "playwright test",
    "test:smoke": "playwright test --project=chromium --grep @smoke",
    "test:e2e": "playwright test --project=chromium --grep @e2e",
    "test:api": "playwright test --project=api --grep @api",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:ui": "playwright test --ui",
    "test:report": "playwright show-report",
    "lint": "tsc --noEmit",
    "clean": "rm -rf test-results playwright-report"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.3.0",
    "dotenv": "^17.3.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "winston": "^3.19.0"
  }
}
